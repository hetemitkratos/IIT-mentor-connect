generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String              @id @default(uuid())
  name          String?
  email         String              @unique
  emailVerified DateTime?
  image         String?
  role          Role                @default(aspirant)
  createdAt     DateTime            @default(now()) @map("created_at")
  accounts      Account[]
  bookings      Booking[]           @relation("StudentBookings")
  applications  MentorApplication[]
  mentor        Mentor?
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model MentorApplication {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  iit             String
  branch          String
  year            Int
  rank            String?           @map("air_rank")
  state           String            @default("")
  languages       String[]
  bio             String
  calLink         String            @map("calendly_link")
  collegeIdUrl    String            @map("college_id_url")
  status          ApplicationStatus @default(pending)
  rejectionReason String?           @map("rejection_reason")
  reviewedAt      DateTime?         @map("reviewed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  user            User              @relation(fields: [userId], references: [id])

  @@map("mentor_applications")
}

model Mentor {
  id           String    @id @default(uuid())
  userId       String    @unique @map("user_id")
  iit          String
  branch       String
  year         Int
  rank         String?   @map("air_rank")
  state        String    @default("")
  languages    String[]
  bio          String
  calLink         String    @map("calendly_link")
  calAccessToken  String?   @map("cal_access_token")
  calRefreshToken String?   @map("cal_refresh_token")
  calUsername     String?   @map("cal_username")
  calConnected    Boolean   @default(false) @map("cal_connected")
  profileImage    String?   @map("profile_image_url")
  isActive        Boolean   @default(true) @map("is_active")

  // Phase 2 Availability Fields
  availableSlots         Json?     @map("available_slots")
  timezone               String?   @default("Asia/Kolkata")
  availabilityConfigured Boolean   @default(false) @map("availability_configured")
  calEventTypeId         String?   @map("cal_event_type_id")

  // Phase 3 Public Slug
  slug                    String?   @unique @default(uuid())
  
  createdAt       DateTime  @default(now()) @map("created_at")
  bookings        Booking[]
  user            User      @relation(fields: [userId], references: [id])

  @@index([iit])
  @@index([branch])
  @@index([year])
  @@map("mentors")
}

model Booking {
  id              String        @id @default(uuid())
  mentorId        String        @map("mentor_id")
  studentId       String        @map("student_id")
  sessionToken    String        @unique @default(uuid()) @map("session_token")
  calEventId      String?       @map("calendly_event_id")
  meetingLink     String?       @map("meeting_link")
  startTime       DateTime?     @map("start_time")
  endTime         DateTime?     @map("end_time")
  status          BookingStatus @default(payment_pending)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  
  // Phase 3 Slot Booking Details
  selectedDay      String?   @map("selected_day")
  selectedSlot     String?   @map("selected_slot")
  paymentExpiresAt DateTime? @map("payment_expires_at")
  otp             String?
  otpGeneratedAt  DateTime?     @map("otp_generated_at")
  otpVerified     Boolean       @default(false) @map("otp_verified")
  rating          Int?
  review          String?       @db.VarChar(300)
  mentor          Mentor        @relation(fields: [mentorId], references: [id])
  student         User          @relation("StudentBookings", fields: [studentId], references: [id])
  payment         Payment?

  @@index([status, createdAt])
  @@index([status, updatedAt])
  @@map("bookings")
}

model Payment {
  id                String        @id @default(uuid())
  bookingId         String        @unique @map("booking_id")
  razorpayOrderId   String        @unique @map("razorpay_order_id")
  razorpayPaymentId String?       @map("razorpay_payment_id")
  amount            Int
  platformFee       Int           @default(5000) @map("platform_fee")
  mentorAmount      Int           @default(10000) @map("mentor_amount")
  currency          String        @default("INR")
  status            PaymentStatus @default(pending)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  booking           Booking       @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model WebhookEvent {
  id         String   @id @default(uuid())
  source     String
  eventId    String   @unique @map("event_id")
  payload    Json
  processed  Boolean  @default(false)
  error      String?
  receivedAt DateTime @default(now()) @map("received_at")

  @@map("webhook_events")
}

enum Role {
  aspirant
  mentor
  admin
}

enum ApplicationStatus {
  pending
  approved
  rejected
}

enum BookingStatus {
  payment_pending
  awaiting_payment
  payment_complete
  scheduled
  in_progress
  completed
  cancelled
}

enum PaymentStatus {
  pending
  successful
  failed
  refunded
}
