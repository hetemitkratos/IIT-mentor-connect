generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String              @id @default(uuid())
  name          String?
  email         String              @unique
  emailVerified DateTime?
  image         String?
  role          Role                @default(aspirant)
  createdAt     DateTime            @default(now()) @map("created_at")
  accounts      Account[]
  bookings      Booking[]           @relation("StudentBookings")
  applications  MentorApplication[]
  mentor        Mentor?
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model MentorApplication {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  iit             String
  branch          String
  year            Int
  rank            String?           @map("air_rank")
  state           String            @default("")
  languages       String[]
  bio             String
  calLink         String            @map("calendly_link")
  collegeIdUrl    String            @map("college_id_url")
  status          ApplicationStatus @default(pending)
  rejectionReason String?           @map("rejection_reason")
  reviewedAt      DateTime?         @map("reviewed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  user            User              @relation(fields: [userId], references: [id])

  @@map("mentor_applications")
}

model Mentor {
  id           String    @id @default(uuid())
  userId       String    @unique @map("user_id")
  iit          String
  branch       String
  year         Int
  rank         String?   @map("air_rank")
  state        String    @default("")
  languages    String[]
  bio          String

  // Primary scheduling link (Cal.com)
  calLink         String?   @map("calendly_link")

  // @deprecated — legacy Cal.com OAuth fields; retained for zero-downtime, never written to
  calAccessToken  String?   @map("cal_access_token")
  calRefreshToken String?   @map("cal_refresh_token")
  calUsername     String?   @map("cal_username")
  calConnected    Boolean   @default(false) @map("cal_connected")
  calEventTypeId  String?   @map("cal_event_type_id")

  // @deprecated — old JSON blob availability; retained for zero-downtime, never written to
  availableSlots         Json?    @map("available_slots")
  timezone               String?  @default("Asia/Kolkata")
  availabilityConfigured Boolean  @default(false) @map("availability_configured")

  profileImage    String?   @map("profile_image_url")
  isActive        Boolean   @default(true) @map("is_active")

  // Phase 3 Public Slug
  slug            String?   @unique @default(uuid())

  createdAt       DateTime  @default(now()) @map("created_at")
  bookings        Booking[]
  // @deprecated — Slot model is soft-deprecated; use Availability instead
  slots           Slot[]
  availability    Availability[]
  user            User      @relation(fields: [userId], references: [id])

  @@index([iit])
  @@index([branch])
  @@index([year])
  @@map("mentors")
}

// @deprecated — Slot model is soft-deprecated. Use Availability for weekly recurring schedules.
// Slot rows are no longer written. Table retained for zero-downtime. Will be dropped in a future cleanup migration.
model Slot {
  id        String   @id @default(cuid())
  mentorId  String   @map("mentor_id")
  mentor    Mentor   @relation(fields: [mentorId], references: [id])

  date      DateTime
  startTime String   @map("start_time") // Format: "16:00"

  isActive  Boolean  @default(true) @map("is_active")

  @@unique([mentorId, date, startTime])
  @@index([mentorId, date])
  @@map("slots")
}

// Weekly recurring availability — replaces the Slot model.
model Availability {
  id        String  @id @default(cuid())
  mentorId  String  @map("mentor_id")
  mentor    Mentor  @relation(fields: [mentorId], references: [id])

  dayOfWeek Int     @map("day_of_week") // 0 = Sunday, 1 = Monday ... 6 = Saturday
  startTime String  @map("start_time")  // e.g. "06:00"
  endTime   String  @map("end_time")    // e.g. "22:00"

  isActive  Boolean @default(true) @map("is_active")

  @@unique([mentorId, dayOfWeek])
  @@index([mentorId, dayOfWeek])
  @@map("availability")
}

model SlotLock {
  id        String   @id @default(cuid())

  mentorId  String   @map("mentor_id")
  date      DateTime
  startTime String   @map("start_time")
  
  bookingId String?  @map("booking_id")

  expiresAt DateTime @map("expires_at")

  @@unique([mentorId, date, startTime])
  @@map("slot_locks")
}

model Booking {
  id              String        @id @default(uuid())
  mentorId        String        @map("mentor_id")
  studentId       String        @map("student_id")
  sessionToken    String        @unique @default(uuid()) @map("session_token")
  calEventId      String?       @map("calendly_event_id")
  meetingLink     String?       @map("meeting_link")
  
  status          BookingStatus @default(pending)
  source          String        @default("internal")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  
  // Phase 3 Slot Booking Details
  date            DateTime?
  startTime       String?       @map("start_time")
  endTime         String?       @map("end_time")

  selectedDay       String?   @map("selected_day")
  selectedSlot      String?   @map("selected_slot")
  externalScheduled Boolean   @default(false) @map("external_scheduled")
  paymentExpiresAt  DateTime? @map("payment_expires_at")
  bookingNote       String?   @map("booking_note")

  // Cal.com webhook data
  scheduledAt       DateTime? @map("scheduled_at")
  meetingUrl        String?   @map("meeting_url")
  attendeeEmail     String?   @map("attendee_email")
  externalEventId   String?   @unique @map("external_event_id")
  otp               String?
  otpGeneratedAt    DateTime? @map("otp_generated_at")
  otpVerified       Boolean   @default(false) @map("otp_verified")
  rating            Int?
  review            String?   @db.VarChar(300)
  mentor            Mentor    @relation(fields: [mentorId], references: [id])
  student           User      @relation("StudentBookings", fields: [studentId], references: [id])
  payment           Payment?

  @@index([status, createdAt])
  @@index([status, updatedAt])
  @@map("bookings")
}

model Payment {
  id                String        @id @default(uuid())
  bookingId         String        @unique @map("booking_id")
  razorpayOrderId   String        @unique @map("razorpay_order_id")
  razorpayPaymentId String?       @map("razorpay_payment_id")
  amount            Int
  platformFee       Int           @default(5000) @map("platform_fee")
  mentorAmount      Int           @default(10000) @map("mentor_amount")
  currency          String        @default("INR")
  status            PaymentStatus @default(pending)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  booking           Booking       @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model WebhookEvent {
  id         String   @id @default(uuid())
  source     String
  eventId    String   @unique @map("event_id")
  payload    Json
  processed  Boolean  @default(false)
  error      String?
  receivedAt DateTime @default(now()) @map("received_at")

  @@map("webhook_events")
}

// @deprecated — legacy Cal.com webhook buffer; retained for zero-downtime.
/// Buffer to prevent race conditions when Cal.com webhook arrives
/// before the student's booking record has been created.
model CalWebhookBuffer {
  id              String    @id @default(cuid())
  externalEventId String    @unique @map("external_event_id")
  attendeeEmail   String    @map("attendee_email")
  mentorId        String?   @map("mentor_id")
  scheduledAt     DateTime  @map("scheduled_at")
  meetingUrl      String?   @map("meeting_url")
  processed       Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("cal_webhook_buffer")
}

enum Role {
  aspirant
  mentor
  admin
}

enum ApplicationStatus {
  pending
  approved
  rejected
}

enum BookingStatus {
  pending
  paid
  cancelled
  completed
}

enum PaymentStatus {
  pending
  successful
  failed
  refunded
}
