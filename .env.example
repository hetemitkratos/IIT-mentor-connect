# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=""                # Pooler URL — postgres://user:pass@pooler-host/dbname?pgbouncer=true
DIRECT_URL=""                  # Direct URL — used by Prisma Studio / migrate (bypasses PgBouncer)
                               # Recommended: Neon (https://neon.tech)

# ── Auth (NextAuth.js) ────────────────────────────────────────────────────
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET=""             # openssl rand -base64 32

# ── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Payments (Razorpay) ───────────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ── Cron (protects /api/cron/* routes) ───────────────────────────────────
CRON_SECRET=""                 # Any random string

# ── Cal.com OAuth ─────────────────────────────────────────────────────────
# Register an OAuth app at https://app.cal.com/settings/developer/oauth-clients
CAL_CLIENT_ID=""
CAL_CLIENT_SECRET=""
CAL_REDIRECT_URI="https://your-domain.com/api/auth/cal/callback"
