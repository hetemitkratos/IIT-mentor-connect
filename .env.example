# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Auth ──────────────────────────────────────────────────────────
NEXTAUTH_URL="https://candidconversations.in"
NEXTAUTH_SECRET=""             # openssl rand -base64 32

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=""                # postgres://user:pass@host:5432/dbname
DIRECT_URL=""                  # used by Prisma Studio / migrate / db pull (bypasses PgBouncer)
                               # Recommended: Neon (https://neon.tech)

# ── Supabase (mentor profile image uploads) ────────────────────────
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── Payments (Razorpay) ───────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ── Scheduling (Cal.com OAuth) ────────────────────────────────────
# Register an OAuth app at https://app.cal.com/settings/developer/oauth-clients
CAL_CLIENT_ID=""
CAL_CLIENT_SECRET=""
CAL_REDIRECT_URI="https://candidconversations.in/api/auth/cal/callback"

# ── Cron (protects /api/cron/* routes) ───────────────────────────
CRON_SECRET=""                 # Any random string
